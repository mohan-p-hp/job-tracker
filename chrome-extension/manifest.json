{
  "manifest_version": 3,
  "name": "JobTracker Capture",
  "version": "1.0",
  "description": "Save jobs from LinkedIn, Indeed and Naukri to your JobTracker",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://indeed.com/*",
    "https://www.indeed.com/*",
    "https://www.naukri.com/*",
    "https://naukricampus.naukri.com/*",
    "http://localhost:5000/*",
    "https://job-tracker-2u65.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobTracker",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://indeed.com/viewjob*",
        "https://www.indeed.com/viewjob*",
        "https://www.naukri.com/*",
        "https://naukricampus.naukri.com/*",
        "https://job-tracker-2u65.onrender.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
